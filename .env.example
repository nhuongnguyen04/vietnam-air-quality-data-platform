# Vietnam Air Quality Data Platform
# ==================================
# Sao chép file này thành .env và điền các giá trị thực.
# TUYỆT ĐỐI KHÔNG commit .env vào git.

# --- ClickHouse ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=your_clickhouse_password_here
CLICKHOUSE_SECURE=false
CLICKHOUSE_DATABASE=air_quality
CLICKHOUSE_DB=air_quality

# --- AQICN ---
# Token miễn phí tại https://aqicn.org/data-platform/token/
AQICN_API_TOKEN=your_aqicn_api_token_here

# --- OpenWeather ---
# Token miễn phí tại https://openweathermap.org/api
OPENWEATHER_API_TOKEN=your_openweather_api_token_here
TOMTOM_API_KEY=your_tomtom_api_key_here

# --- Text-to-SQL (Phase 10) ---
# Dashboard points to the internal service URL; production should keep this on the internal Docker network.
TEXT_TO_SQL_URL=http://text-to-sql:8000
# First Vanna/Groq SQL generation can be slow while the runtime warms up.
TEXT_TO_SQL_TIMEOUT_SECONDS=90
# Vanna OSS uses Groq as the underlying OpenAI-compatible LLM provider.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
# Vanna runtime lifecycle and persistence.
TEXT_TO_SQL_VANNA_CLIENT=chromadb
TEXT_TO_SQL_VANNA_COLLECTION=air_quality_ask_data
TEXT_TO_SQL_VANNA_PERSIST_DIRECTORY=/data/vanna
TEXT_TO_SQL_VANNA_REBUILD=false
# Dedicated read-only ClickHouse credentials for the text-to-SQL service.
TEXT_TO_SQL_CLICKHOUSE_USER=aqi_reader
TEXT_TO_SQL_CLICKHOUSE_PASSWORD=change-me
# Required secret used to sign preview tokens before `/execute`.
TEXT_TO_SQL_PREVIEW_SECRET=replace-with-a-long-random-secret

# --- Airflow ---
# Admin credentials injected into AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS.
AIRFLOW_ADMIN_USERNAME=airflow_admin
AIRFLOW_ADMIN_PASSWORD=replace-with-a-strong-password
# Secret key cho Airflow API, webserver và scheduler.
# TẠO GIÁ TRỊ MỚI cho mỗi môi trường (không dùng giá trị mẫu trong production).
AIRFLOW__CORE__FERNET_KEY=replace-with-a-generated-fernet-key
AIRFLOW_API_SECRET_KEY=change-me-in-prod-use-long-random-string
AIRFLOW_API_AUTH_JWT_SECRET=change-me-in-prod-use-long-random-string
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-in-prod-use-long-random-string

# --- Google Drive landing zone ---
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
GDRIVE_ROOT_FOLDER_ID=

# --- Grafana Alerting (Telegram) ---
# Grafana admin password for the local monitoring UI.
GF_SECURITY_ADMIN_PASSWORD=replace-with-a-grafana-admin-password
# Bot 1: Air Quality alerts → Telegram group chat (public)
# Bot 2: System monitoring alerts → Telegram private chat (admin)
# Tạo bot tại https://t.me/BotFather, lấy chat_id từ @userinfobot hoặc @RawDataBot
TELEGRAM_AQ_BOT_TOKEN=your_air_quality_bot_token_here
TELEGRAM_AQ_CHAT_ID=your_air_quality_group_chat_id_here
TELEGRAM_SYS_BOT_TOKEN=your_system_monitoring_bot_token_here
TELEGRAM_SYS_CHAT_ID=your_system_monitoring_private_chat_id_here

# --- OpenMetadata (Phase 4) ---
OPENMETADATA_URL=http://openmetadata:8585/api
OM_ADMIN_USER=admin@open-metadata.org
OM_ADMIN_PASSWORD=admin
POSTGRES_OM_DB=openmetadata_db
POSTGRES_OM_USER=openmetadata_user
POSTGRES_OM_PASSWORD=openmetadata_password
CLICKHOUSE_OM_READER_USER=om_reader
CLICKHOUSE_OM_READER_PASSWORD=om_reader_secure_pass

# --- Mapbox (Dashboard Phase 07.1) ---
# Optional: Mapbox token for custom map styles (free tier: 50K loads/month)
# Get token at https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=
