    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-airquality"
      },
      "description": "ClickHouse Query throughput (queries per minute)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqpm"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "id": 6,
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-airquality"
          },
          "queryType": "sql",
          "rawSql": "SELECT $__timeGroup(event_time, '1m') as time, count() as queries FROM system.query_log WHERE event_date >= toDate($__from/1000) AND event_time >= toDateTime($__from/1000) GROUP BY 1 ORDER BY 1"
        }
      ],
      "title": "ClickHouse Query Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-airquality"
      },
      "description": "Average query duration (ms)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "id": 7,
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-airquality"
          },
          "queryType": "sql",
          "rawSql": "SELECT $__timeGroup(event_time, '1m') as time, avg(query_duration_ms) as avg_latency FROM system.query_log WHERE event_date >= toDate($__from/1000) AND event_time >= toDateTime($__from/1000) AND type = 'QueryFinish' GROUP BY 1 ORDER BY 1"
        }
      ],
      "title": "Avg Query Latency",
      "type": "timeseries"
    },
