      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-airquality"
          },
          "editorMode": "code",
          "format": "table",
          "group": [],
          "groupBy": [],
          "hide": false,
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT\n  source,\n  last_success,\n  lag_seconds,\n  records_ingested,\n  CASE\n    WHEN lag_seconds > 10800 THEN '🔴 Stale (>3h)'\n    WHEN lag_seconds > 3600  THEN '🟡 Late (>1h)'\n    ELSE '🟢 Fresh'\n  END AS freshness_status\nFROM ingestion_control\nORDER BY lag_seconds DESC",
          "refId": "A",
          "rollingWindow": 10,
          "source": "metric",
          "timeColumn": "last_success",
          "whereCol": "",
          "whereIsNull": false
        }
      ],
      "title": "Max Timestamp UTC per Source",
      "type": "table"
    },
