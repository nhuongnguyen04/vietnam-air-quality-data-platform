          "rawSql": "SELECT\n  task_id,\n  avg(duration) AS avg_duration_sec,\n  toDate(start_date) AS run_date\nFROM task_instance\nWHERE duration IS NOT NULL\n  AND start_date >= now() - INTERVAL 7 DAY\nGROUP BY task_id, run_date\nORDER BY run_date",
