      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "last_success_epoch"
          }
        ]
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "airflow-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "group": [],
          "groupBy": [],
          "hide": false,
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT\n  dag_id,\n  max(end_date) AS last_success,\n  floor(extract(epoch from (now() - max(end_date)))) AS last_success_epoch,\n  CASE\n    WHEN max(end_date) < now() - INTERVAL '2 hour' THEN '🔴 Failed (>2h)'\n    WHEN max(end_date) < now() - INTERVAL '1 hour' THEN '🟡 Late (>1h)'\n    ELSE '🟢 OK'\n  END AS status\nFROM dag_run\nWHERE state = 'success'\nGROUP BY dag_id\nORDER BY last_success DESC",
          "refId": "A",
          "maxDataPoints": 300,
          "rollingWindow": 10,
          "source": "metric",
          "timeColumn": "end_date",
          "whereCol": "state",
          "whereIsNull": false
        }
      ],
      "title": "Last DAG Success (Traffic Light)",
      "type": "table"
    },
