        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "airflow-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "group": [],
          "groupBy": [],
          "hide": false,
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT\n  state,\n  count(*) AS run_count,\n  toDate(start_date) AS run_date\nFROM dag_run\nWHERE start_date >= now() - INTERVAL 7 DAY\nGROUP BY state, run_date\nORDER BY run_date",
          "refId": "A",
          "maxDataPoints": 300,
          "rollingWindow": 10,
          "source": "metric",
          "timeColumn": "start_date",
          "whereCol": "state",
          "whereIsNull": false
        }
      ],
      "title": "DAG Success Rate (7-day)",
      "type": "barchart"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "airflow-postgres"
      },
      "description": "Last successful DAG run per DAG — traffic light status",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
